rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Fotos de propriedades ─────────────────────────────────────────────────
    // Cada usuário lê, faz upload e exclui somente dentro da sua própria pasta.
    // Upload restrito a imagens e vídeos com tamanho máximo por tipo.
    match /fotos/{userId}/{fileName} {
      allow read: if request.auth != null
                  && request.auth.uid == userId;

      allow create, update: if request.auth != null
                  && request.auth.uid == userId
                  && (
                    // Imagens: até 10 MB
                    (request.resource.contentType.matches('image/.*')
                     && request.resource.size <= 10 * 1024 * 1024)
                    ||
                    // Vídeos: até 200 MB
                    (request.resource.contentType.matches('video/.*')
                     && request.resource.size <= 200 * 1024 * 1024)
                  );

      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }

    // ── Downloads públicos (instaladores DMG / EXE) ───────────────────────────
    // Arquivos na raiz do bucket são de leitura pública.
    // Escrita ocorre exclusivamente via service account no deploy.sh
    // (Admin SDK ignora as Security Rules).
    match /{fileName} {
      allow read:  if true;
      allow write: if false;
    }
  }
}
