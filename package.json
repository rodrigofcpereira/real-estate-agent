{
  "name": "lf-imoveis",
  "version": "1.0.0",
  "description": "LF Imóveis - Gerenciamento de clientes e WhatsApp",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron": "electron .",
    "prepare-chromium": "node scripts/copy-chromium.js",
    "rebuild": "electron-rebuild -f -w whatsapp-web.js",
    "dist": "electron-builder build",
    "dist:mac": "npm run prepare-chromium && npm run rebuild && electron-builder build --mac",
    "dist:win": "npm run rebuild && electron-builder build --win"
  },
  "build": {
    "afterPack": "scripts/afterPack.js",
    "appId": "com.lfimoveis.app",
    "productName": "LF Imóveis",
    "files": [
      "main.js",
      "server.js",
      "app.js",
      "auth.js",
      "firebase.js",
      "app.html",
      "style.css",
      "package.json",
      "node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "extraResources": [
      {
        "from": "resources/chromium",
        "to": "chromium",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg"
      ],
      "icon": null,
      "identity": null,
      "sign": false,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asar": true,
    "asarUnpack": []
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.2",
    "whatsapp-web.js": "github:pedroslopez/whatsapp-web.js#main"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "electron": "~40.10.2",
    "electron-builder": "^26.0.0",
    "nodemon": "^3.0.2"
  }
}
